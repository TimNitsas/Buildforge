{
  "openapi": "3.1.1",
  "info": {
    "title": "Buildforge.Service | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/builds": {
      "get": {
        "tags": [
          "Build"
        ],
        "parameters": [
          {
            "name": "Skip",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "uint32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/BuildResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/builds/updates": {
      "get": {
        "tags": [
          "Build"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BuildStatus"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BuildStatus"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BuildStatus"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Build": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "BuildResult": {
        "required": [
          "builds"
        ],
        "type": "object",
        "properties": {
          "builds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Build"
            }
          }
        }
      },
      "BuildStatus": {
        "type": "object",
        "anyOf": [
          {
            "$ref": "#/components/schemas/BuildStatusBuildStatusFailed"
          },
          {
            "$ref": "#/components/schemas/BuildStatusBuildStateSuccess"
          }
        ],
        "discriminator": {
          "propertyName": "discriminator"
        }
      },
      "BuildStatusBuildStateSuccess": {
        "required": [
          "buildTime"
        ],
        "properties": {
          "buildTime": {
            "pattern": "^-?(\\d+\\.)?\\d{2}:\\d{2}:\\d{2}(\\.\\d{1,7})?$",
            "type": "string"
          }
        }
      },
      "BuildStatusBuildStatusFailed": {
        "required": [
          "reason"
        ],
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Build"
    }
  ]
}