<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mi="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <SolidColorBrush x:Key="Red" Color="Red" />
    <SolidColorBrush x:Key="Blue" Color="CornflowerBlue" />
    <SolidColorBrush x:Key="Green" Color="ForestGreen" />
    <SolidColorBrush x:Key="Orange" Color="DarkOrange" />
    <SolidColorBrush x:Key="Gray" Color="DimGray" />

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#737373" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />

    <Style TargetType="DataGrid">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#F9F9F9" />
    </Style>

    <Style TargetType="DataGridCell">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ContextMenuMaterialIconStyle" TargetType="mi:MaterialIcon">
        <Setter Property="Height" Value="12" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Gray}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>