<UserControl
    x:Class="Buildforge.App.Control.Badge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Buildforge.App.Control"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="20"
    d:DesignWidth="100"
    mc:Ignorable="d">
    <Border
        Height="16"
        Padding="2"
        VerticalAlignment="Center"
        d:Background="Green"
        Background="{Binding Color, RelativeSource={RelativeSource AncestorType=UserControl}}"
        CornerRadius="4">
        <TextBlock
            VerticalAlignment="Center"
            d:Text="Badge Text Design That Is Long"
            FontSize="10"
            FontWeight="SemiBold"
            Foreground="White"
            Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />
    </Border>
</UserControl>