<UserControl
    x:Class="Buildforge.App.Control.NavigationIcon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Buildforge.App.Control"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mi="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    d:DesignHeight="32"
    d:DesignWidth="32"
    mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="NavigationIconColor" Color="#a8a8a8" />
        <SolidColorBrush x:Key="NavigationIconHoveredColor" Color="#737373" />
        <Style TargetType="mi:MaterialIcon">
            <Setter Property="Foreground" Value="{StaticResource NavigationIconColor}" />
            <Setter Property="FontSize" Value="18" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource NavigationIconHoveredColor}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Button Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <mi:MaterialIcon Kind="{Binding IconKind, RelativeSource={RelativeSource AncestorType=UserControl}}" ToolTip="{Binding Tooltip, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </Button>
</UserControl>