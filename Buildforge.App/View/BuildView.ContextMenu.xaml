<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mi="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:view="clr-namespace:Buildforge.App.ViewModel.Build">
    <ContextMenu x:Key="RowContextMenu">
        <MenuItem Command="{Binding DownloadCommand}">
            <MenuItem.Icon>
                <mi:MaterialIcon Foreground="{StaticResource Gray}" Kind="Download" />
            </MenuItem.Icon>
            <MenuItem.Header>
                Download
            </MenuItem.Header>
        </MenuItem>
    </ContextMenu>
</ResourceDictionary>