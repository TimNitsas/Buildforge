<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mi="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:view="clr-namespace:Buildforge.App.ViewModel.Contribution">
    <ContextMenu x:Key="ContributionViewItemContextMenu">
        <MenuItem>
            <MenuItem.Icon>
                <mi:MaterialIcon Kind="Forward" Style="{StaticResource ContextMenuMaterialIconStyle}"/>
            </MenuItem.Icon>
            <MenuItem.Header>
                Request Integration To Live
            </MenuItem.Header>
        </MenuItem>
        <MenuItem>
            <MenuItem.Icon>
                <mi:MaterialIcon Kind="Forward" Style="{StaticResource ContextMenuMaterialIconStyle}"/>
            </MenuItem.Icon>
            <MenuItem.Header>
                Request Integration To Stable
            </MenuItem.Header>
        </MenuItem>
    </ContextMenu>
</ResourceDictionary>